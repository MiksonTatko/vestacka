# ==============================================================================
# 0) NEOPHODNI IMPORTI
# ==============================================================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sb
import sklearn.cluster as cluster
from scipy.cluster.hierarchy import linkage, dendrogram
from scipy.stats.mstats import winsorize
from sklearn.preprocessing import MinMaxScaler

# ==============================================================================
# 1) UCITAVANJE PODATAKA I KREIRANJE PODSKUPA (Zahtev 1)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU:
# - Putanju do fajla ('spotify.csv') zamenjuješ svojom putanjom.
# - Naziv kolone ("speechiness") i uslov (<= 60) menjaš na osnovu teksta zadatka.
data = pd.read_csv('spotify.csv')
cl_data = data[data["speechiness"] <= 60].copy()

# ==============================================================================
# 2) ODABIR I SELEKCIJA ATRIBUTA (Istraživanje + Egzekucija)
# ==============================================================================
print("--- Pregled informacija o bazi ---")
print(cl_data.info())
print("\n--- Deskriptivna statistika (Provera varijanse) ---")
print(cl_data.describe())

# ⚠️ ŠTA MENJAŠ NA ISPITU:
# - U .drop() listu unosiš identifikatore (npr. 'track_name') i kolone koje
#   prema tabeli iznad nemaju varijansu (skoro sve nule, npr. 'instrumentalness').
cl_data.drop(columns=["track_name", "instrumentalness"], inplace=True, errors='ignore')

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Selekciju):
Iz procesa klasterizacije inicijalno je isključen tekstualni identifikator 'track_name' jer ne poseduje informacionu vrednost za računanje geometrijske udaljenosti. Analizom deskriptivne statistike (funkcija .describe()) uočeno je da varijabla 'instrumentalness' sadrži nule sve do 75. kvartila, što ukazuje na ekstremno nisku varijansu i nemogućnost diskriminacije objekata, pa je takođe izbačena iz daljeg postupka.
"""

# ==============================================================================
# 3) PRIPREMA PODATAKA, IMPUTACIJA I LOGIČKE KOREKCIJE
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Nazive kolona koje tvoj zadatak zahteva da se srede (pd.to_numeric i mapiranje).
cl_data["in_spotify_charts"] = pd.to_numeric(cl_data["in_spotify_charts"], errors='coerce')
cl_data["mode"] = cl_data["mode"].map({'Major': 0, 'Minor': 1})

cl_data.replace(['-', ' ', ''], np.nan, inplace=True)

print("\n--- Broj nedostajućih vrednosti pre imputacije ---")
print(cl_data.isnull().sum())

for col in cl_data.select_dtypes(include=[np.number]).columns:
    if cl_data[col].isnull().sum() > 0:
        cl_data[col].fillna(cl_data[col].median(), inplace=True)

# ⚠️ ŠTA MENJAŠ NA ISPITU: Korekciju nula radiš samo ako 0 logički označava "nema ga na listi"
cl_data.loc[cl_data["in_apple_charts"] == 0, "in_apple_charts"] = cl_data["in_apple_charts"].max()
cl_data.loc[cl_data["in_spotify_charts"] == 0, "in_spotify_charts"] = cl_data["in_spotify_charts"].max()

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Imputaciju):
Sve skrivene i neadekvatno unete vrednosti ('-', ' ') uspešno su prevedene u NaN vrednosti. S obzirom na to da raspodele kontinualnih podataka pokazuju izrazitu asimetriju pod uticajem ekstremnih vrednosti, kao najpouzdaniji metod imputacije odabrana je MEDIJANA. Kategorička varijabla 'mode' je mapirana u binarni format. Izvršena je i logička korekcija anomalije na rang listama gde vrednost 0 označava odsustvo sa liste: sve nule su zamenjene maksimalnom (najlošijom) pozicijom, kako algoritam ne bi interpretirao nulu kao najbolji rezultat.
"""

# ==============================================================================
# 4) ANALIZA KORELACIJE I MULTIKOLINEARNOSTI (Istraživanje + Drop)
# ==============================================================================
plt.figure(figsize=(8, 6))
sb.heatmap(cl_data.corr(), cmap="Blues", annot=True)
plt.title("Korelaciona matrica pre redukcije")
plt.show()

# ⚠️ ŠTA MENJAŠ NA ISPITU: Pogledaš grafikon iznad i izbacuješ kolone sa r > 0.70 (ovde npr. 'in_apple_playlists' i 'streams')
cl_data.drop(columns=["in_apple_playlists", "streams"], inplace=True, errors='ignore')

# ==============================================================================
# 5) DETEKCIJA AUTLAJERA I WINSORIZATION (Puni istraživački krug)
# ==============================================================================
print("\n--- Generisanje Boxplot grafikona za analizu autlajera ---")
numericke_kolone = cl_data.select_dtypes(include=[np.number]).columns
for col in numericke_kolone:
    plt.figure(figsize=(5, 2))
    plt.boxplot(cl_data[col], vert=False)
    plt.title(f"Boxplot za kolonu: {col}")
    plt.show()

# ⚠️ ŠTA MENJAŠ NA ISPITU:
# - Ako kolona ima preko 10% autlajera (gust blok tačaka daleko od brkova) -> IDE U DROP.
# - Ako ima manje autlajera -> PRIMENJUJEŠ WINSORIZE.
cl_data.drop(columns=["in_spotify_playlists", "released_year", "in_apple_charts", "speechiness"], inplace=True, errors='ignore')

cl_data["bpm"] = winsorize(cl_data["bpm"], limits=[0.00, 0.02])
cl_data["energy"] = winsorize(cl_data["energy"], limits=[0.01, 0.00])
cl_data["liveness"] = winsorize(cl_data["liveness"], limits=[0.00, 0.05])

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Autlajere):
Vizuelnom analizom pomoću boxplot grafikona identifikovano je prisustvo ekstremnih autlajera. Kolone poput 'in_spotify_playlists' i 'released_year' su pokazale kontaminaciju autlajerima koja prelazi 10% ukupnog uzorka, zbog čega su eliminisane kako ne bi iskrivile klaster strukturu. Na varijablama sa umerenim autlajerima (bpm, energy, liveness) primenjena je tehnika vnzorizacije (Winsorize) na nivoima od 1% do 5%, čime su ekstremne vrednosti zamenjene najbližim stabilnim vrednostima na krajevima raspodele.
"""

# ==============================================================================
# 6) SKALIRANJE PODATAKA
# ==============================================================================
scaler = MinMaxScaler()
cl_data_scaled = pd.DataFrame(scaler.fit_transform(cl_data), columns=cl_data.columns)

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Skaliranje):
Za potrebe hijerarhijske klasterizacije primenjena je normalizacija pomoću MinMaxScaler-a, čime su svi atributi svedeni na uniforman opseg [0, 1]. Ovaj korak je obavezan jer algoritmi distanci tretiraju varijable sa većim prirodnim rasponom kao dominantne, što bi distorziralo stvarne geometrijske odnose između instanci.
"""

# ==============================================================================
# 7) PRIKAZ DENDROGRAMA I ODREDJIVANJE K I LINKAGE METODE
# ==============================================================================
fig, axes = plt.subplots(2, 2, figsize=(14, 10))
methods = ['ward', 'single', 'complete', 'average']
axes_flat = axes.flatten()

for idx, method in enumerate(methods):
    plt.sca(axes_flat[idx])
    dendrogram(linkage(cl_data_scaled, method=method, metric='euclidean'), no_labels=True)
    axes_flat[idx].set_title(f"{method.capitalize()} linkage")
plt.tight_layout()
plt.show()

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Dendrogram):
Analizom dendrograma za četiri različite metode povezivanja, 'Ward' metoda (koja minimizuje unutar-klastersku varijansu) pokazuje geometrijski najstabilniju i najčistiju strukturu grananja. Na primarnom nivou (najveći vertikalni skok bez preseka pravih) jasno se uočava podela na K = 2 klastera, dok horizontalni rez na nešto nižoj distanci otvara stabilnu podjelu na K = 4 klastera. Usvajamo Ward metodu i evaluiraćemo oba rešenja.
"""

# ==============================================================================
# 8) FINALNA KLASTERIZACIJA I VELIČINA KLASTERA
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Broj klastera u petlji [2, 4] postavljaš na vrednosti očitane sa tvog dendrograma.
for k in [2, 4]:
    if "cluster" in cl_data_scaled.columns: 
        cl_data_scaled.drop(columns=["cluster"], inplace=True)
    h_cluster = cluster.AgglomerativeClustering(n_clusters=k, linkage="ward", metric="euclidean")
    cl_data_scaled["cluster"] = h_cluster.fit_predict(cl_data_scaled)
    print(f"\n--- Veličina klastera za K={k} ---")
    print(cl_data_scaled["cluster"].value_counts())