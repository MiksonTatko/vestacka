# ==============================================================================
# 0) NEOPHODNI IMPORTI
# ==============================================================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sb
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.tree import DecisionTreeClassifier, plot_tree
from sklearn.metrics import confusion_matrix, classification_report

# ==============================================================================
# 1) UCITAVANJE PODATAKA I KREIRANJE VARIJABLE (Zahtev 1 i 2)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Naziv fajla ('bank.csv') i uslov za kreiranje ciljne varijable (ovde: "Stayed" na osnovu "Exited").
df_tree = pd.read_csv('bank.csv')

df_tree["Stayed"] = np.where(df_tree["Exited"] == 0, 1, 0)

print("--- Pregled tipova kolona pre mapiranja tekstualnih varijabli ---")
print(df_tree.dtypes)

# Ručno mapiranje svih tekstualnih kolona jer scikit-learn stabla ne rade sa tekstom!
df_tree.drop(columns=["Surname", "Exited"], inplace=True, errors='ignore')
df_tree.replace(['-', ' ', ''], np.nan, inplace=True)

if "Gender" in df_tree.columns: 
    df_tree["Gender"] = df_tree["Gender"].map({'Male': 0, 'Female': 1})
if "Geography" in df_tree.columns:
    df_tree["Geography"] = df_tree["Geography"].map({val: idx for idx, val in enumerate(df_tree["Geography"].unique())})
if "Card. Type" in df_tree.columns:
    df_tree["Card. Type"] = df_tree["Card. Type"].map({val: idx for idx, val in enumerate(df_tree["Card. Type"].unique())})

for col in df_tree.select_dtypes(include=[np.number]).columns:
    if df_tree[col].isnull().sum() > 0:
        df_tree[col].fillna(df_tree[col].median(), inplace=True)

X = df_tree.drop(columns=["Stayed"])
y = df_tree["Stayed"]

X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=0, stratify=y)

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Pripremu kod Stabla):
Identifikacione kolone poput 'Surname' su uklonjene jer bi stablo kroz njih napravilo pseudo-savršeno grananje bez ikakve generalizacione moći. Kategoričke varijable uspešno su transformisane u numeričke forme jer biblioteka scikit-learn zahteva isključivo numeričku ulaznu matricu. Nedostajuće vrednosti su imputirane medijanom. Skaliranje kod stabla odlučivanja NIJE potrebno jer su pravila grananja invarijantna na monotone transformacije atributa.
"""

# ==============================================================================
# 2) KROS-VALIDACIJA ZA OPTIMALNO CCP_ALPHA (Zahtev 5)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Parametar cv=10 prebaci u cv=5 ako zadatak eksplicitno traži 5-fold kros-validaciju.
clf = DecisionTreeClassifier(random_state=0)
path = clf.cost_complexity_pruning_path(X_train, y_train)
ccp_alphas = [a for a in path.ccp_alphas if a >= 0][:20]

parametri = {'ccp_alpha': ccp_alphas}
grid_tree = GridSearchCV(DecisionTreeClassifier(random_state=0), parametri, cv=10, scoring='accuracy')
grid_tree.fit(X_train, y_train)

optimalno_alpha = grid_tree.best_params_['ccp_alpha']
print(f"Optimalna vrednost ccp_alpha dobijena post-pruning metodom je: {optimalno_alpha}")

# ==============================================================================
# 3) FINALNI MODEL I VIZUELIZACIJA STABLA (Zahtev 6)
# ==============================================================================
tree_final = DecisionTreeClassifier(ccp_alpha=optimalno_alpha, random_state=0)
tree_final.fit(X_train, y_train)

# max_depth=3 osigurava da stablo na grafikonu ostane čitljivo i pregledno
plt.figure(figsize=(18, 10))
plot_tree(tree_final, feature_names=X.columns, class_names=["No", "Yes"], filled=True, max_depth=3)
plt.title("Vizuelna struktura potkresanog stabla odlučivanja (Pruned Tree)")
plt.show()

# ==============================================================================
# 4) EVALUACIJA MODELA - MATRICA I METRIKE (Zahtev 7)
# ==============================================================================
y_pred = tree_final.predict(X_test)

cm = confusion_matrix(y_test, y_pred)
sb.heatmap(cm, annot=True, fmt='d', cmap='Greens')
plt.ylabel('Stvarna klasa')
plt.xlabel('Predviđena klasa')
plt.title("Matrica konfuzije - Stablo odlučivanja")
plt.show()

print(classification_report(y_test, y_pred))

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Evaluaciju Stabla):
1. Matrica konfuzije: Omogućava direktan uvid u tačnost predikcije. Ispravno klasifikovane instance na glavnoj dijagonali (True Positive i True Negative) dominiraju matricom, što dokazuje da je model uspešno ekstrahovao logička pravila ponašanja iz atributa.
2. Četiri evaluacione metrike:
   - Accuracy (Tačnost): Odnosi se na ukupan udeo tačnih predikcija u odnosu na sve testne uzorke.
   - Precision (Preciznost): Meri udeo stvarno lojalnih klijenata među svima koje je model označio da ostaju (klasa 1).
   - Recall (Osetljivost): Pokazuje procenat uspešno identifikovanih klijenata koji ostaju u odnosu na njihov ukupan stvarni broj. Izuzetno važna metrika za pravovremeno uočavanje rizika odliva.
   - F1-score: Predstavlja balansiranu harmonijsku sredinu preciznosti i osetljivosti, pružajući jedinstvenu ocenu kvaliteta modela u uslovima blage neravnoteže klasa.
"""