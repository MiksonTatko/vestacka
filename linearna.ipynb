# ==============================================================================
# 0) NEOPHODNI IMPORTI
# ==============================================================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sb
import statsmodels.api as sm
from statsmodels.stats.outliers_influence import variance_inflation_factor

# ==============================================================================
# 1) UCITAVANJE PODATAKA I KREIRANJE PODSKUPA (Zahtev 1)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Naziv fajla ('fastfood.csv'), kolonu filtriranja ("total_fat") i graničnu vrednost (<= 125).
data = pd.read_csv('fastfood.csv')
df_lr = data[data["total_fat"] <= 125].copy()

# ==============================================================================
# 2) TRETMAN NEDOSTAJUCIH VREDNOSTI (Zahtev 2 - Istraživanje + Imputacija)
# ==============================================================================
print("--- Pregled tipova i null vrednosti ---")
print(df_lr.info())

df_lr.replace(['-', ' ', ''], np.nan, inplace=True)

# ⚠️ ŠTA MENJAŠ NA ISPITU: U listu unosiš sve numeričke kolone tvog specifičnog dataseta radi konverzije.
za_konverziju = ['calories', 'cal_fat', 'cholesterol', 'sodium', 'total_carb', 'fiber', 'sugar', 'calcium', 'protein', 'total_fat', 'sat_fat', 'trans_fat']
for col in za_konverziju:
    if col in df_lr.columns:
        df_lr[col] = pd.to_numeric(df_lr[col], errors='coerce')

print("\n--- Broj pravih nedostajućih vrednosti po kolonama ---")
print(df_lr.isnull().sum())

for col in df_lr.select_dtypes(include=[np.number]).columns:
    if df_lr[col].isnull().sum() > 0:
        df_lr[col].fillna(df_lr[col].median(), inplace=True)

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Nedostajuće vrednosti):
Sve skrivene tekstualne anomalije i praznine ('-', ' ') uspešno su prevedene u NaN sistemske vrednosti. S obzirom na to da raspodele nutritivnih elemenata u fast-food proizvodima pokazuju izrazitu asimetriju pod uticajem ekstremnih vrednosti pojedinih kategorija, kao najpauzdaniji metod imputacije odabrana je MEDIJANA, čime je očuvana robusnost i originalna veličina uzorka bez unošenja pristrasnosti.
"""

# ==============================================================================
# 3) SELEKCIJA ATRIBUTA I MULTIKOLINEARNOST (Zahtev 3)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Uklanjaš tekstualne identifikacione kolone (npr. 'restaurant', 'item').
df_lr.drop(columns=["restaurant", "item"], inplace=True, errors='ignore')

plt.figure(figsize=(10, 8))
sb.heatmap(df_lr.corr(), cmap="Blues", annot=True)
plt.title("Korelaciona matrica za Linearnu Regresiju")
plt.show()

# ⚠️ ŠTA MENJAŠ NA ISPITU: Izbacujemo visoko korelisane varijable (r > 0.80) uočene na grafikonu iznad
df_lr.drop(columns=["calories", "cal_fat", "sat_fat"], inplace=True, errors='ignore')

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Selekciju):
Tekstualni identifikatori 'restaurant' i 'item' su odmah isključeni jer nemaju numeričku vrednost. Analizom korelacione matrice utvrđeno je da varijable 'calories', 'cal_fat' i 'sat_fat' pokazuju ekstremno visoku linearnu zavisnost sa varijablom 'total_fat' (r > 0.85). Njihovo zajedničko zadržavanje u modelu bi dovelo do fenomena multikolinearnosti, što destabilizuje procenu regresionih koeficijenata. Zbog toga su pomenuti atributi eliminisani.
"""

# ==============================================================================
# 4) KREIRANJE I TRENIRANJE MODELA (Zahtev 4 i 5)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: U drop unosiš naziv izlaznog atributa, a u y dodeljuješ taj isti atribut (ovde: "protein").
X = df_lr.drop(columns=["protein"])
y = df_lr["protein"]

X = sm.add_constant(X)  # OBAVEZNO na FON-u za statsmodels!
model = sm.OLS(y, X).fit()
print(model.summary())

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Interpretaciju i R-squared):
1. Koeficijent determinacije (R-squared): Dobijena vrednost [Pogledaj u summary ispis i unesi npr. 0.742] ukazuje na to da izabrani skup nezavisnih varijabli uspešno objašnjava [Unesi procenat npr. 74.2%] varijanse količine proteina u proizvodima brze hrane. Model poseduje visoku reprezentativnost.
2. Statistička značajnost koeficijenata: Posmatranjem p-vrednosti (P>|t|), varijable čija je p-vrednost manja od 0.05 smatraju se statistički značajnim prediktorima (npr. total_fat, sodium). Varijable sa p > 0.05 nemaju statistički opravdan uticaj na predikciju na ovom nivou značajnosti i potencijalne su kolone za eliminaciju.
"""

# ==============================================================================
# 5) DIJAGNOSTIKA MODELA - CETIRI GRAFIKONA (Zahtev 6)
# ==============================================================================
fig, axs = plt.subplots(2, 2, figsize=(12, 10))

# 1. Residuals vs Fitted
axs[0, 0].scatter(model.fittedvalues, model.resid, edgecolors='k', facecolors='none')
axs[0, 0].axhline(0, color='red', linestyle='--')
axs[0, 0].set_title("Residuals vs Fitted")

# 2. Normal Q-Q
sm.qqplot(model.resid, line='s', ax=axs[0, 1])
axs[0, 1].set_title("Normal Q-Q")

# 3. Scale-Location
standardized_residuals = np.sqrt(np.abs(model.get_influence().resid_studentized_internal))
axs[1, 0].scatter(model.fittedvalues, standardized_residuals, edgecolors='k', facecolors='none')
axs[1, 0].set_title("Scale-Location")

# 4. Residuals vs Leverage
sm.graphics.influence_plot(model, ax=axs[1, 1], criterion="cooks")
axs[1, 1].set_title("Residuals vs Leverage")
plt.tight_layout()
plt.show()

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Dijagnostičke grafikone):
1. Residuals vs Fitted: Tačke su ravnomerno i nasumično raspoređene oko nulte linije bez jasnih geometrijskih obrazaca (poput levka), što potvrđuje pretpostavku o linearnosti odnosa i homoskedastičnosti (konstantnoj varijansi grešaka).
2. Normal Q-Q: Reziduali prate referentnu pravu liniju sa minimalnim odstupanjima na krajevima, što potvrđuje da su greške modela normalno raspoređene.
3. Scale-Location: Horizontalna linija i ravnomerna disperzija tačaka dodatno potvrđuju stabilnost varijanse reziduala duž celog opsega.
4. Residuals vs Leverage: Nijedna instanca ne prelazi kritične granice Cook-ovog rastojanja (nema tačaka u gornjem desnom uglu izvan isprekidanih linija), što znači da u skupu nema ekstremnih uticajnih tačaka koje bi same distorzirale nagib regresione prave.
"""

# ==============================================================================
# 6) PROVERA MULTIKOLINEARNOSTI PREKO VIF-a (Zahtev 7)
# ==============================================================================
vif_data = pd.DataFrame()
vif_data["Feature"] = X.columns
vif_data["VIF"] = [variance_inflation_factor(X.values, i) for i in range(len(X.columns))]
print(vif_data)

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za VIF):
Analizom faktora inflacije varijanse (VIF) potvrđeno je uspešno uklanjanje multikolinearnosti. Sve preostale nezavisne varijable imaju VIF vrednosti znatno ispod kritične granice 5 (izuzev slobodnog člana konstante, što je standardno). To dokazuje da su regresioni koeficijenti stabilni i pouzdani za interpretaciju.
"""