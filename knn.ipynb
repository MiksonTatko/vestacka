# ==============================================================================
# 0) NEOPHODNI IMPORTI
# ==============================================================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sb
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.preprocessing import MinMaxScaler
from sklearn.neighbors import KNeighborsClassifier
from sklearn.metrics import confusion_matrix, classification_report

# ==============================================================================
# 1) UCITAVANJE PODATAKA I LOGIČKA PRIPREMA CILJNE VARIJABLE (Zahtev 1 i 2)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Naziv fajla ('spotify.csv') i uslov za kreiranje binarne varijable na osnovu kvartila.
df_knn = pd.read_csv('spotify.csv')

df_knn["streams"] = pd.to_numeric(df_knn["streams"], errors='coerce')
df_knn["streams"].fillna(df_knn["streams"].median(), inplace=True)

q3_streams = df_knn["streams"].quantile(0.75)
df_knn["HighStreams"] = np.where(df_knn["streams"] > q3_streams, 1, 0)

# Istraživački pregled pre dropovanja
print("--- Pregled kolona pre brisanja ---")
print(df_knn.info())

df_knn.drop(columns=["track_name", "streams"], inplace=True, errors='ignore')
df_knn.replace(['-', ' ', ''], np.nan, inplace=True)

df_knn["in_spotify_charts"] = pd.to_numeric(df_knn["in_spotify_charts"], errors='coerce')
df_knn["mode"] = df_knn["mode"].map({'Major': 0, 'Minor': 1})

for col in df_knn.select_dtypes(include=[np.number]).columns:
    if df_knn[col].isnull().sum() > 0:
        df_knn[col].fillna(df_knn[col].median(), inplace=True)

# ⚠️ ŠTA MENJAŠ NA ISPITU: Izbacuješ novokreiranu ciljnu kolonu iz X, a dodeljuješ je u y.
X = df_knn.drop(columns=["HighStreams"])
y = df_knn["HighStreams"]

# ==============================================================================
# 2) SKALIRANJE PODATAKA (OBAVEZNO ZA KNN) (Zahtev 3)
# ==============================================================================
scaler = MinMaxScaler()
X_scaled = scaler.fit_transform(X)

X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.3, random_state=0, stratify=y)

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Skaliranje kod KNN):
Algoritam KNN klasifikacije donosi odluke na osnovu geometrijske udaljenosti (Euklidske distance) između tačaka u višedimenzionalnom prostoru. Ukoliko se podaci ne skaliraju, atributi sa prirodno većim rasponima vrednosti bi potpuno dominirali nad onima sa manjim rasponom, čineći ih beskorisnim. Zbog toga je primenjen MinMaxScaler koji sve atribute prevodi na uniformnu skalu od 0 do 1. Podaci su podeljeni u odnosu 70:30 uz stratifikaciju.
"""

# ==============================================================================
# 3) KROS-VALIDACIJA ZA ODREDJIVANJE OPTIMALNOG K (Zahtev 4)
# ==============================================================================
# ⚠️ ŠTA MENJAŠ NA ISPITU: Parametar cv=10 prebaci u cv=5 ako zadatak traži 5-fold kros-validaciju.
parametri = {'n_neighbors': [i for i in range(1, 21) if i % 2 != 0]}

grid_search = GridSearchCV(KNeighborsClassifier(), parametri, cv=10, scoring='accuracy')
grid_search.fit(X_train, y_train)

optimalno_k = grid_search.best_params_['n_neighbors']
print(f"Optimalan broj suseda K dobijen kros-validacijom je: {optimalno_k}")

# Vizuelni prikaz kros-validacije (Istraživački korak koji profesori cene)
plt.plot(parametri['n_neighbors'], grid_search.cv_results_['mean_test_score'], marker='o', color='purple')
plt.xlabel("Broj suseda (K)")
plt.ylabel("Kros-validaciona tačnost (Accuracy)")
plt.title("GridSearch optimizacija za parametar K")
plt.show()

# ==============================================================================
# 4) FINALNI MODEL I EVALUACIJA (Zahtev 5 i 6)
# ==============================================================================
knn_final = KNeighborsClassifier(n_neighbors=optimalno_k)
knn_final.fit(X_train, y_train)
y_pred = knn_final.predict(X_test)

cm = confusion_matrix(y_test, y_pred)
sb.heatmap(cm, annot=True, fmt='d', cmap='Purples')
plt.ylabel('Stvarna klasa')
plt.xlabel('Predviđena klasa')
plt.title(f"Matrica konfuzije za KNN (K={optimalno_k})")
plt.show()

print(classification_report(y_test, y_pred))

"""
📝 KOMENTAR ZA ISPIT (Prepiši u Markdown za Evaluaciju KNN):
1. Matrica konfuzije: Rezultati pokazuju stabilnu raspodelu na glavnoj dijagonali (True Positive i True Negative), dok su greške tipa I i tipa II minimizovane zahvaljujući kros-validacijom optimizovanom parametru K.
2. Četiri klasifikacione metrike:
   - Accuracy (Ukupna tačnost) prikazuje procenat tačnih predikcija na celom test setu.
   - Precision (Preciznost) ukazuje na udeo stvarno pozitivnih instanci među onima koje je model proglasio pozitivnim (1).
   - Recall (Osetljivost) meri sposobnost modela da prepozna sve stvarne pripadnike pozitivne klase (pesme sa visokim brojem strimova).
   - F1-score kao njihova harmonijska sredina potvrđuje visoku prediktivnu stabilnost modela.
"""